# https://editorconfig.org/
root = true

# Unix-style newlines with a newline ending every file
[*]
end_of_line = lf
insert_final_newline = true

[{*.yaml,*.yml}]
indent_size = 2
indent_style = space

# Tab indentation (no size specified)
[Makefile]
indent_style = tab

[*.py]
indent_style = space
indent_size = 4

# shell scripts
[{*.sh,*.zsh,*.nu}]
indent_size = 4
indent_style = space
